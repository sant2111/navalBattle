<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import com.example.navalbattle.view.GridBoardPane?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.navalbattle.controller.BoardSetupController"
            styleClass="welcome-root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="setup-header">
            <padding>
                <Insets top="14" right="20" bottom="14" left="20"/>
            </padding>
            <Button fx:id="backButton" text="← Volver" styleClass="ghost-button-light" onAction="#handleBackAction"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="COLOCA TU FLOTA" styleClass="title-label-light"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="remainingShipsLabel" styleClass="remaining-label"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="AS_NEEDED" styleClass="welcome-scroll">
            <HBox spacing="24" alignment="CENTER" styleClass="welcome-container">
                <padding>
                    <Insets top="24" right="28" bottom="24" left="28"/>
                </padding>

                <VBox alignment="CENTER" spacing="10">
                    <Label text="Arrastra cada barco hasta la grilla (⟳ lo rota antes de soltarlo). Ya puesto, arrástralo de nuevo para moverlo, o haz doble clic para rotarlo." styleClass="hint-label" wrapText="true" maxWidth="360"/>
                    <GridBoardPane fx:id="gridBoardPane"/>
                </VBox>

                <Separator orientation="VERTICAL"/>

                <VBox spacing="12" styleClass="fleet-panel" prefWidth="230">
                    <Label text="FLOTA PENDIENTE" styleClass="section-header"/>
                    <VBox fx:id="fleetListContainer" spacing="10"/>
                    <Separator styleClass="section-divider-thin"/>
                    <Button fx:id="randomPlacementButton" text="Colocación aleatoria" maxWidth="Infinity"
                            styleClass="secondary-button" onAction="#handleRandomPlacementAction"/>
                    <Button fx:id="undoButton" text="Deshacer" maxWidth="Infinity"
                            styleClass="tertiary-button" onAction="#handleUndoAction" disable="true"/>
                    <Button fx:id="resetButton" text="Reiniciar tablero" maxWidth="Infinity"
                            styleClass="tertiary-button" onAction="#handleResetAction"/>
                </VBox>
            </HBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" styleClass="setup-footer">
            <padding>
                <Insets top="14" right="20" bottom="14" left="20"/>
            </padding>
            <Button fx:id="startGameButton" text="Comenzar partida" styleClass="primary-button"
                    onAction="#handleStartGameAction" disable="true"/>
        </HBox>
    </bottom>
</BorderPane>
